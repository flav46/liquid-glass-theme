{
  "name": "liquid-glass-os",
  "version": "1.0.0",
  "private": true,
  "description": "Liquid Glass Desktop OS Simulation",
  "author": {
    "name": "Liquid Glass Team",
    "email": "dev@liquidglass.os"
  },
  "main": "electron/main.js",

  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",

    "electron": "env -u ELECTRON_RUN_AS_NODE electron .",

    "electron-dev": "concurrently \"vite\" \"wait-on http://localhost:5173 && env -u ELECTRON_RUN_AS_NODE electron .\"",

    "dist": "npm run build && electron-builder"
  },

  "dependencies": {
    "framer-motion": "12.38.0",
    "react": "18.2.0",
    "react-dom": "18.2.0"
  },

  "devDependencies": {
    "@types/react": "18.3.28",
    "@types/react-dom": "18.3.7",
    "@vitejs/plugin-react": "4.7.0",

    "vite": "7.3.2",
    "typescript": "5.2.2",

    "electron": "31.7.7",
    "electron-builder": "24.13.3",

    "concurrently": "9.2.1",
    "wait-on": "8.0.5"
  },

  "build": {
    "appId": "com.liquidglass.os",
    "productName": "Liquid Glass OS",
    "files": [
      "dist/**/*",
      "electron/**/*"
    ],
    "directories": {
      "buildResources": "assets"
    },
    "linux": {
      "target": "AppImage",
      "category": "Utility"
    }
  }
}