{
  "name": "iphone-liquid-glass-theme",
  "private": true,
  "version": "1.0.0",
  "description": "Liquid Glass Theme Desktop App",
  "main": "electron/main.js",
  "scripts": {
    "dev": "vite --port 5173 --strictPort",
    "build": "tsc && vite build",
    "lint": "eslint . --ext ts,tsx",
    "preview": "vite preview",
    "electron": "env -u ELECTRON_RUN_AS_NODE electron .",
    "electron-dev": "concurrently \"npm run dev\" \"wait-on http://localhost:5173 && env -u ELECTRON_RUN_AS_NODE electron .\"",
    "dist": "npm run build && electron-builder --publish=never"
  },
  "dependencies": {
    "framer-motion": "^12.38.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "devDependencies": {
    "@types/react": "^18.3.28",
    "@types/react-dom": "^18.3.7",
    "@vitejs/plugin-react": "^4.7.0",
    "concurrently": "^9.2.1",
    "electron": "^41.2.1",
    "typescript": "^5.2.2",
    "vite": "^5.4.21",
    "wait-on": "^8.0.5"
  }
}
